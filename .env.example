# Vehicle Counting App — environment configuration
# Copy to .env and fill in real values.

# RTSP camera stream
RTSP_URL=rtsp://admin:password@192.168.105.120:554/cam/realmonitor?channel=1&subtype=1

# Target ingestion FPS
TARGET_FPS=20

# Hailo model (compiled HEF for yolov8m). Leave empty to auto-resolve via
# the hailo-apps model zoo (resolve_hef_path).
HEF_PATH=

# Postgres connection (psycopg3 DSN)
DATABASE_URL=postgresql://vehicle_app:vehicle_pass@localhost:5432/vehicle_counts

# How often (minutes) to persist total_count to Postgres
PERSIST_INTERVAL_MINUTES=5

# Directory where a .jpg snapshot is saved each time a new vehicle is detected
DEBUG_DIR=debug
